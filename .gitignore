# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Telos identity files — version-controlled override of nanoclaw's per-installation defaults.
# Identity (soul.md), addenda (CLAUDE.local.md), and tick/reflect prompts encode the
# agent's character and behavior — tracked. container.json stays per-installation
# (it embeds agent_group_id and host-side mount paths).
#
# Telos has three sibling groups (one per session: work/learn/life). Each group has
# its own addendum + tick prompts. The MCP tools live ONCE at shared/telos-tools/
# and are mounted into every Telos session's container via additionalMounts —
# avoiding duplicated tools/ is an ADR-013 silent-rot mitigation.

# work session group
!groups/telos/
groups/telos/*
!groups/telos/soul.md
!groups/telos/CLAUDE.local.md
!groups/telos/tick-prompt.md
!groups/telos/tick-morning-prompt.md
!groups/telos/tick-midday-prompt.md
!groups/telos/tick-evening-prompt.md
!groups/telos/reflect-prompt.md

# learn session group
!groups/telos-learn/
groups/telos-learn/*
!groups/telos-learn/soul.md
!groups/telos-learn/CLAUDE.local.md
!groups/telos-learn/tick-morning-prompt.md
!groups/telos-learn/tick-recall-prompt.md
!groups/telos-learn/tick-midpoint-prompt.md
!groups/telos-learn/tick-capture-prompt.md
!groups/telos-learn/tick-close-prompt.md
!groups/telos-learn/container.example.json

# life session group
!groups/telos-life/
groups/telos-life/*
!groups/telos-life/soul.md
!groups/telos-life/CLAUDE.local.md
!groups/telos-life/tick-morning-prompt.md
!groups/telos-life/tick-bodycheck-prompt.md
!groups/telos-life/tick-transition-prompt.md
!groups/telos-life/tick-workout-prompt.md
!groups/telos-life/tick-close-prompt.md
!groups/telos-life/container.example.json

# Shared Telos MCP tools — single source of truth, mounted into every Telos
# group's container at /workspace/extra/telos-tools/.
!shared/
!shared/telos-tools/
!shared/telos-tools/**

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
